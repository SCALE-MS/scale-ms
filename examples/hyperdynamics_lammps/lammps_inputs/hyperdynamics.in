units 			metal
boundary 		p p p 
atom_style 		full
neigh_modify    delay 5 every 5 check yes
pair_style 		eam/fs 


read_data	min.data
pair_coeff 		* * AgX1.0.eam.alloy  Ag


thermo			1000000
thermo_style	custom step temp etotal pe ke vol
thermo_modify	flush yes

dump			1 all custom 1000000 mov.lammpstrj id mol type q x y z
dump_modify		1 sort id

restart         1000000 restart.1 restart.2 
restart         5000000 fs.*

group Boost id 501 301:400
group NonBoost subtract all Boost

fix 1 all langevin 600.0 600.0 1000.0 495079
fix 2 all nve
compute event all event/displace 1.2
fix diffusion Boost hyper/global 3.32 0.3 1.0 600
fix 3 all momentum 1 linear 1 1 1 angular
hyper 125000000 100 diffusion event